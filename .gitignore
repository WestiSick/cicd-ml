db/seed/snapshot.sql.gz
ml/registry/*
!ml/registry/.gitkeep
docs/thesis/figures/*
!docs/thesis/figures/.gitkeep
docs/thesis/screenshots/*
!docs/thesis/screenshots/.gitkeep

