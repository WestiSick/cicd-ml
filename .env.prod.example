# Public domain + Let's Encrypt
DOMAIN=cicd-ml.example.com
LE_EMAIL=you@example.com

# Database
POSTGRES_USER=cicdml
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=cicdml
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# API gateway
API_HOST=api          # docker-compose service name; collector/simulator
                      # use this to push WS broadcasts back to the gateway
API_PORT=8080
API_BIND=0.0.0.0
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
GITHUB_WEBHOOK_SECRET=REPLACE_WITH_STRONG_SECRET

# Public URLs (HTTPS via Traefik)
PUBLIC_API_BASE=https://cicd-ml.example.com
PUBLIC_WS_BASE=wss://cicd-ml.example.com

# Frontend build-time vars
VITE_API_BASE=https://cicd-ml.example.com
VITE_WS_BASE=wss://cicd-ml.example.com

# ML service
ML_PORT=8000
ML_HOST=ml

# Bootstrap
BOOTSTRAP_DEFAULT_MONTHS=6

# Logging
LOG_LEVEL=info
