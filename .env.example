# --- Database -------------------------------------------------------
POSTGRES_USER=cicdml
POSTGRES_PASSWORD=cicdml_dev_password
POSTGRES_DB=cicdml
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ----------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- API gateway ----------------------------------------------------
API_PORT=8080
API_BIND=0.0.0.0
JWT_SECRET=change-me-in-prod
GITHUB_WEBHOOK_SECRET=change-me-in-prod

# Public base URL the frontend uses to talk to the API. In dev — direct.
PUBLIC_API_BASE=http://localhost:8080
PUBLIC_WS_BASE=ws://localhost:8080

# --- ML service -----------------------------------------------------
ML_PORT=8000
ML_HOST=ml

# --- Frontend (Vite dev server) -------------------------------------
FRONTEND_PORT=5173
VITE_API_BASE=http://localhost:8080
VITE_WS_BASE=ws://localhost:8080

# --- Bootstrap defaults (used if user skips onboarding) -------------
BOOTSTRAP_DEFAULT_MONTHS=6

# --- Logging --------------------------------------------------------
LOG_LEVEL=info
